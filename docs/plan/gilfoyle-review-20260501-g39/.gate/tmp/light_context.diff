+        )
+        _patch_api_default_registry(monkeypatch, api_module, _registry)
+
+        payload = api_module.run_scan(str(role_path), include_vars_main=True)
+
+    assert payload["metadata"]["plugin_runtime_marker"] == "resolver-used"
